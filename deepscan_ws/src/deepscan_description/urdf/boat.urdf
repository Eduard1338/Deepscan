<?xml version="1.0"?>
<robot name="deepscan_boat">
  <link name="world"/>
  <link name="base_link">
    <visual>
      <geometry>
        <box size="10 10 10"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <box size="10 10 10"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="50"/>
      <inertia ixx="10" ixy="0" ixz="0" iyy="10" iyz="0" izz="10"/>
    </inertial>
  </link>
  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
</robot>
